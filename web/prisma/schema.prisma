// Balatro League schema.
//
// Domain shape:
//   Season has many Divisions. Division has many Players (via DivisionMember).
//   Inside a Division, every pair of players has exactly one Pairing (the 2-game series, best-of-2).
//   Result is stored as games won by A and B; sum is always 2 once played.
//   A Pairing only counts toward standings once its status is CONFIRMED.
//
// Scoring (points per pairing):
//   2-0 win → 3 pts winner, 0 pts loser
//   1-1 draw → 1 pt each
//   Standings sort by total points (desc). Tiebreakers (in order):
//     1. Head-to-head points between tied players
//     2. Shootout (admin-resolved, recorded via /league force-result)
//
// Division structure: per-season ordered Tiers, each containing 1+ Divisions.
// Position 1 = top tier. Each Division belongs to one Tier and has its own display name.
// Default for new seasons (admin can override): 4 tiers — Legendary, Rare, Uncommon, Common —
// with 1 / 4 / 6 / 6 divisions respectively. Promo/relegation runs between adjacent tier positions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id              String   @id @default(cuid())
  discordId       String   @unique
  // The currently-shown name. Auto-synced from Discord on /me visit UNLESS
  // hasCustomDisplayName=true (user has set their own override).
  displayName     String
  // Whether the player explicitly set their own displayName. False (default)
  // means "let Discord be the source of truth — auto-sync on login." True
  // means "they typed this, leave it alone."
  hasCustomDisplayName Boolean @default(false)
  createdAt       DateTime @default(now())
  // Admin-managed skill rating. Used by auto-seed-by-rating to place players into divisions.
  // Null = unrated (auto-seed treats as 0 / lowest).
  rating          Int?
  // Optional note explaining the rating (e.g. "Balatro MP MMR 540, Glass tier")
  ratingNote      String?

  memberships     DivisionMember[]
  pairingsAsA     Pairing[] @relation("PairingPlayerA")
  pairingsAsB     Pairing[] @relation("PairingPlayerB")
  reportedPairings Pairing[] @relation("PairingReporter")
  disputedPairings Pairing[] @relation("PairingDisputer")
  mmrSnapshots    PlayerMmrSnapshot[]

  @@index([rating])
}

// Scraped point-in-time MMR snapshot from balatromp.com. We capture one
// per signed-up player at signup-close so future seeding decisions can
// reference what their public skill rating was *when they joined this
// season* — not their current rating, which may have drifted by the time
// promo/relegation runs. Admin can also trigger ad-hoc refreshes.
//
// rawHtml retained for forensics: if balatromp restructures their page
// and our parser breaks, we can re-parse historical snapshots without
// re-scraping (their site only shows current state, so historical data
// would otherwise be lost forever).
model PlayerMmrSnapshot {
  id          String   @id @default(cuid())
  // Canonical key — present even when no Player row exists yet (new
  // signups that haven't been turned into Players by build-season).
  discordId   String
  // Set when a Player row exists; null for snapshots captured during
  // signup-close before the new player has been materialized. Backfilled
  // by build-season when it creates the Player row.
  playerId    String?
  player      Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  // Null = ad-hoc capture not tied to a specific season (e.g., admin
  // hit refresh). Otherwise the season this snapshot was taken FOR
  // (typically the season the player just signed up to).
  seasonId    String?
  capturedAt  DateTime @default(now())
  // Source = "balatromp.com" for now; future-proofs adding other rating
  // sources (e.g., a self-reported manual entry).
  source      String   @default("balatromp.com")
  // BMP-season this snapshot belongs to (e.g. "season6"). Null = captured
  // without specifying a season (request was for current state). Set when
  // we explicitly fetch a prior BMP season so we can show last-2-seasons
  // trend on the profile.
  bmpSeason   String?
  // Nullable because the player may not have an account on balatromp,
  // or the fetch may have failed — we still want a row recording the
  // attempt rather than silently dropping it (fetchError captures why).
  rankedMmr   Int?
  rankedTier  String?
  totalGames  Int?
  // Stored as integer 0-100 (e.g., 52 = 52%). Easier to sort/filter than
  // a float and we don't need sub-percent precision for seeding.
  winRatePct  Int?
  // Direct from the tRPC response — let players see peak MMR they ever
  // hit in this season, raw W/L counts (winRatePct is derived), longest
  // win streak, and leaderboard rank position at capture time.
  peakMmr     Int?
  wins        Int?
  losses      Int?
  peakStreak  Int?
  leaderboardRank Int?
  rawHtml     String?
  fetchError  String?

  @@index([discordId, capturedAt])
  @@index([discordId, bmpSeason, capturedAt])
  @@index([playerId, capturedAt])
  @@index([seasonId])
}

// Light-weight kv-ish vote table for player-page easter eggs (e.g. the
// "impeach Sanji" buttons). targetKey identifies who's being voted on
// (just a string slug — no FK so we can add new targets without a
// migration), side is "yes" / "no". Unique on (targetKey, voterDiscordId)
// so each logged-in user can only vote once per target; submitting the
// opposite side just updates the existing row.
model EasterEggVote {
  id              String   @id @default(cuid())
  targetKey       String
  voterDiscordId  String
  side            String   // "yes" | "no"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([targetKey, voterDiscordId])
  @@index([targetKey, side])
}

model Season {
  id          String   @id @default(cuid())
  // Sequential season number — required and globally unique. The
  // user-facing label is derived as "Season {number}" (with optional
  // " — {subtitle}" suffix), so seasons are identified by their number
  // and not by free-form name. See formatSeasonLabel() helpers.
  number      Int      @unique
  // Optional human subtitle, e.g. "Launch" or "Anniversary". Null for
  // the default label of just "Season N".
  subtitle    String?
  startedAt   DateTime @default(now())
  // If set, the match-sweep loop auto-activates this season (flips
  // isActive=true) the next time it runs after this timestamp. Admin
  // can edit/clear at any point before activation. Cleared on activate.
  scheduledStartAt DateTime?
  endedAt     DateTime?
  // Archived seasons are hidden from default lists (admin + public). Use
  // for old seasons you want kept-but-out-of-the-way.
  archivedAt  DateTime?
  isActive    Boolean  @default(true)
  // Target players per division. Driving fewer games per player → use 4 instead of 5.
  targetGroupSize Int  @default(5)
  // Don't auto-create a division with fewer than this many players (smaller leftover groups
  // are flagged as warnings instead of becoming tiny divisions).
  minGroupSize    Int  @default(3)

  // Which match-config preset /start-match uses for this season. Null falls
  // back to the preset named "Default" at match-time.
  matchConfigPresetId String?
  matchConfigPreset   MatchConfigPreset? @relation(fields: [matchConfigPresetId], references: [id], onDelete: SetNull)

  // League rules template for THIS season (scoring + ban policy +
  // timeouts). Null = use the global default template. Once a season
  // starts, in-flight matches stamp their policy onto the session at
  // accept time so mid-season template changes don't break ongoing
  // play — but new sessions read the season's template.
  leagueRulesTemplateId String?
  leagueRulesTemplate   LeagueRulesTemplate? @relation(fields: [leagueRulesTemplateId], references: [id], onDelete: SetNull)

  // Discord category to nest per-division channels under. Set once per season
  // via /admin/seasons. If null, division channels are created at top level.
  discordCategoryId   String?

  // Per-season overrides for results announcements. If null, fall back to
  // the global LeagueConfig.ResultsWebhookUrl / env RESULTS_CHANNEL_ID.
  // Lets each season post results to its own dedicated channel without
  // having to touch env vars between seasons.
  resultsWebhookUrl   String?
  resultsChannelId    String?

  divisions   Division[]
  tiers       Tier[]

  @@index([isActive])
}

enum SignupStatus {
  OPEN
  CLOSED  // signups locked; awaiting build-season
  BUILT   // converted into a Season
}

// A round of signups. Lives independently of Season so signups for "next season"
// can be collected while the current season is still running.
model SignupRound {
  id                String       @id @default(cuid())
  name              String
  guildId           String
  channelId         String       // channel the signup embed lives in
  messageId         String       // the signup message we re-edit as people sign up
  status            SignupStatus @default(OPEN)
  openedAt          DateTime     @default(now())
  closedAt          DateTime?
  resultingSeasonId String?      // set when build-season turns this into a Season

  signups           Signup[]

  @@index([status])
}

model Signup {
  id          String      @id @default(cuid())
  roundId     String
  discordId   String
  displayName String
  withdrawn   Boolean     @default(false)
  signedUpAt  DateTime    @default(now())

  round       SignupRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, discordId])
  @@index([roundId, withdrawn])
}

// Named match-config preset — admin defines the deck + stake whitelist used
// by /start-match for a season. Multiple presets so admins can save "Standard",
// "Wild Stakes Only", etc. Per-season selection via Season.matchConfigPresetId.
// Falls back to the preset named "Default" if a season hasn't picked one.
model MatchConfigPreset {
  id        String   @id @default(cuid())
  name      String   @unique
  decks     String[] // Postgres array — order is display order
  stakes    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seasons   Season[]
}

// A guided 2-game series session driven by the bot in a Discord thread.
// Tracks coin toss + ban/pick state. When complete, writes a CONFIRMED Pairing.
enum MatchSessionState {
  WAITING_ACCEPT        // posted, awaiting opponent click
  GAME_1_BAN            // banning phase for game 1
  GAME_1_PICK           // first player picks from final 2
  GAME_1_PLAYING        // played in Balatro, waiting for winner report
  GAME_2_CHOOSE_FIRST   // game 1 loser picks who bans first in game 2
  GAME_2_BAN            // banning phase for game 2
  GAME_2_PICK
  GAME_2_PLAYING
  GAME_3_CHOOSE_FIRST   // BO3 only — game 2 loser picks who bans first in game 3
  GAME_3_BAN
  GAME_3_PICK
  GAME_3_PLAYING
  PAUSED                // mutual-consent pause after game 1; pausedFromState remembers where to resume
  COMPLETE              // pairing written (or just done if casual)
  CANCELLED             // never accepted or admin-killed
}

model MatchSession {
  id            String            @id @default(cuid())
  divisionId    String?           // null when isCasual=true (no league context)
  playerAId     String            // initiator (ran /start-match OR /challenge)
  playerBId     String            // opponent
  state         MatchSessionState @default(WAITING_ACCEPT)
  // Set when state=PAUSED — the previous state to resume back to once
  // both players consent. Cleared on resume/cancel/complete.
  pausedFromState MatchSessionState?
  // Player IDs who voted for a pending pause / resume. First click sets
  // it; opposite-player click flips state and clears it.
  pauseInitiatorPlayerId  String?
  resumeInitiatorPlayerId String?
  // Set when the session enters PAUSED. match-sweep cancels paused
  // sessions older than 7 days.
  pausedAt                DateTime?
  // Mutual-consent cancel — first click sets initiator, second click
  // from the other player flips state to CANCELLED. Lives at session
  // level (not per-game) so cancel works from any non-terminal phase.
  cancelInitiatorPlayerId String?
  cancelInitiatedAt       DateTime?
  // Mutual-consent opponent-DC claim during a PLAYING phase (claimant
  // player id). Opponent confirms (forfeits the game) or disputes.
  dcInitiatorPlayerId     String?
  // Bumped on every update; used for optimistic concurrency control so
  // racing button clicks can't double-write the state machine. Any update
  // is gated by `where: { id, version }` — a stale click hits 0 rows updated.
  version       Int               @default(0)
  // Casual /challenge match — no division/season required, no Pairing
  // written at COMPLETE, no auto-announce. Otherwise uses the same
  // ban/pick state machine and Discord rendering.
  isCasual      Boolean           @default(false)
  // 1, 2, or 3. 1 = one game and done. 2 = league default. 3 = play game 3
  // only if game 1 and 2 split (1-1 W-L).
  bestOf        Int               @default(2)
  // True when this is a tiebreaker shootout (e.g. /start-match mode:shootout
  // between two players tied for promo/relegation after a 1-1 regular-season
  // h2h). Forces bestOf=1 and writes a Shootout row instead of a Pairing
  // at COMPLETE. Mutually exclusive with isCasual in practice.
  isShootout    Boolean           @default(false)
  threadId      String?           // Discord thread id (set once accepted)
  channelId     String?           // parent channel of the thread
  // Discord message id of the public match embed. Stored so the
  // private ban-menu (ephemeral) flow can edit the public message
  // cross-interaction via REST when bans are confirmed. Set once
  // when the message is first posted; survives state changes.
  matchMessageId String?

  // Set the first time a helper is summoned for this match (via the
  // Call helper button). Gates re-calls so the helper role can't be
  // re-pinged for the same match. Claimed atomically to also beat a
  // simultaneous double-click.
  helperCalledAt DateTime?

  // JSON blobs so we can evolve state shape without migrations.
  pool          String?           // [{deck, stake}, ...] generated at accept
  // Snapshot of the league match policy at session-create time: JSON of
  // {firstPlayerBans, secondPlayerBans, poolSize, picksFromRemaining}.
  // Null = fall back to current LeagueSettings defaults (covers legacy
  // rows from before this column existed). Stored on the session so an
  // in-flight match never breaks if an admin tweaks the policy mid-game.
  policy        String?
  // Locked-in agreed deck/stake combo. Set ONLY when both players have
  // agreed via the in-thread propose/accept flow (or via the legacy
  // slash-command args, deprecated). JSON {deck, stake}. When set, the
  // match skips ban/pick entirely — every game uses this combo. Null
  // = normal ban/pick path.
  customCombo   String?
  // In-flight proposal during negotiation. JSON: { by: playerId of the
  // proposer, deck?: string, stake?: string, status: 'building' |
  // 'pending' }. 'building' = proposer is still picking their deck or
  // stake; 'pending' = proposal complete, waiting for the OTHER player
  // to Accept / Counter / Cancel. Cleared once a proposal is agreed
  // to (moved into customCombo) or cancelled.
  customComboProposal String?
  game1         String?           // {firstId, bans: [...], pickedDeck, winnerId}
  game2         String?
  game3         String?           // populated only when bestOf=3 and game 1+2 split

  pairingId     String?           // populated when COMPLETE (only for league matches)

  createdAt     DateTime          @default(now())
  // Bumps automatically on every Prisma update via @updatedAt.
  // Used by match-sweep to find stale sessions (no activity for 24h)
  // and auto-cancel them, so abandoned mid-game sessions don't stick
  // around forever.
  updatedAt     DateTime          @updatedAt @default(now())
  // When the invite expires (WAITING_ACCEPT only). Survives bot restarts —
  // the previous setTimeout-only approach lost timers on every deploy.
  expiresAt     DateTime?
  acceptedAt    DateTime?
  completedAt   DateTime?
  // Set once the archive.stale-threads cron has locked + archived the
  // session's Discord thread (or determined the thread is gone). Lets
  // the sweep skip already-processed sessions cheaply. The inline
  // closeMatchChannel() on completion sets this too on success so the
  // cron has nothing to do for happy-path matches.
  threadArchivedAt DateTime?

  @@index([state])
  @@index([threadId])
  @@index([state, expiresAt])
  // Cron predicate: sweep COMPLETE/CANCELLED sessions whose thread
  // hasn't been archived yet. Composite so the planner can walk the
  // ones it cares about.
  @@index([state, threadArchivedAt])
}

// Binding between a Discord role and a bot permission tier.
// Multiple Discord roles can map to the same tier (e.g. two separate
// "League Helper" roles).
enum PermissionTier {
  OWNER   // full power, including destructive ops + role binding
  ADMIN   // season/division management, force-resolve disputes, export
  HELPER  // dispute mediation: join match channels, record verbal results
  DEVOPS  // infra alerts only (queue stalls, rate-limit floods). Does
          // NOT grant league-admin powers — distinct surface from ADMIN
          // so the people who can debug stack traces aren't pinged for
          // game mediation, and vice versa.
}

// Global key-value config for the bot — things like the results-webhook
// URL that need to be admin-editable at runtime without an env-var redeploy.
// Kept generic so we can stash more values here later (announce category,
// etc.) without a migration per setting.
model LeagueConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?  // Discord ID of whoever set it
}

// Opt-in list for next-season notifications. Bot DMs every entry when
// admin opens a new signup round. Decoupled from Player so non-league
// members (who logged in but never joined) can also subscribe.
model SeasonInterest {
  id           String   @id @default(cuid())
  discordId    String   @unique
  subscribedAt DateTime @default(now())
}

model RoleBinding {
  id            String         @id @default(cuid())
  discordRoleId String         @unique
  tier          PermissionTier
  createdAt     DateTime       @default(now())
  createdBy     String?        // discord user id of who set it

  @@index([tier])
}

// Saved tier layout admins can pick from when creating a season.
// `config` is JSON-encoded array: [{name, divisionCount}, ...] in order.
// A magic "Last used" template is auto-upserted after every season create
// so the form pre-fills with the most recent shape.
model TierTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  config    String   // JSON array of TierConfig
  isLastUsed Boolean @default(false)
  updatedAt DateTime @updatedAt
}

// Per-season tier. Position 1 = top of the pyramid (e.g., Legendary).
// Each tier groups 1+ divisions. Promotion/relegation runs between adjacent positions.
model Tier {
  id        String     @id @default(cuid())
  seasonId  String
  position  Int        // 1 = top. Determines promo/relegation order.
  name      String     // Display name: "Legendary", "Champions", etc.
  // How many players promote up from THIS tier (top N) and relegate
  // down (bottom N) at end-of-season. Symmetric — one field for both
  // directions. Drives ↑/↓ markers on /standings; end-season recompute
  // doesn't care since next-season build seeds by global rank.
  promoteRelegateCount Int @default(1)

  season    Season     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  divisions Division[]

  @@unique([seasonId, position])
  @@unique([seasonId, name])
  @@index([seasonId])
}

model Division {
  id          String   @id @default(cuid())
  seasonId    String
  tierId      String
  // Index within the tier (1-based). Sibling divisions at the same tier are parallel.
  groupNumber Int
  // Display label, e.g. "Rare 3", "Legendary", or any custom name.
  name        String
  // Optional per-division target size — overrides Season.targetGroupSize for
  // this division's "X/Y players" display + auto-assign behavior. Lets a
  // division be intentionally larger or smaller than the season default
  // without affecting other divisions.
  targetSize  Int?
  // Optional Discord role + channel IDs the bot manages for this division
  discordRoleId    String?
  discordChannelId String?
  // End-of-season champion role + winner. Set when admin clicks
  // 'Award champion roles' on an ended season. Role persists forever
  // as a bragging-rights badge. championPlayerId is the rank-1
  // finisher — null when admin hasn't awarded yet OR the division had
  // an unresolved tie at #1 (skipped, re-runnable after shootout).
  championRoleId    String?
  championPlayerId  String?

  season      Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  tier        Tier              @relation(fields: [tierId], references: [id], onDelete: Cascade)
  members     DivisionMember[]
  pairings    Pairing[]

  standings   DivisionStandings?
  shootouts   Shootout[]

  @@unique([seasonId, tierId, groupNumber])
  @@index([seasonId])
  @@index([tierId])
  // Hot path: command-channels.ts looks up "is this channel a division
  // channel" on every match-flow slash command. Index avoids a seq scan
  // even though the table is small.
  @@index([discordChannelId])
}

// Materialized standings cache: precomputed StandingRow[] for one
// division, kept in sync via recomputeDivisionStandings() called from
// every place that writes a Pairing. Reads hit this instead of running
// computeStandings on raw pairings each page-load.
//
// Cold-cache reads (no row yet) fall back to computing on the fly and
// populating the cache as a side effect, so we don't need a one-shot
// backfill migration — the cache warms naturally as divisions get
// visited or new Pairings get written.
model DivisionStandings {
  divisionId String   @id
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  computedAt DateTime @default(now()) @updatedAt
  // JSON-serialized CachedStandingRow[] — minimal payload (player ids
  // + numeric stats, no display names). Render-time join hydrates
  // Player rows so display name changes show immediately without a
  // cache rebuild.
  rowsJson   String
}

// Shootout result for a tied promo/relegation pair. Only consulted when
// the standings sort can't separate two players via points + head-to-head
// (i.e., they drew 1-1 against each other in the round-robin). Winner
// sorts above loser. One shootout per pair per division — unique
// constraint enforces that.
//
// Recorded by /admin record-shootout (Helper+) or /report-shootout
// (self-service, auto-confirmed). Standings cache recomputes on any
// Shootout write so the sort reflects the result immediately.
// Tracks where the public report embed for a Pairing was posted, so the
// 2-min auto-confirm job and the Confirm/Dispute button handlers can
// re-edit it in place. Added alongside the opponent-confirms reporting
// flow — was redundant when /report auto-confirmed immediately.
//
// Kept as direct columns on Pairing (vs a side table) because they're
// 1:1 with the row's lifecycle and queried on every confirm/dispute
// interaction.

model Shootout {
  id          String   @id @default(cuid())
  divisionId  String
  division    Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  // Canonical order: playerAId < playerBId by id. Same ordering as
  // Pairing so we can look up either pair (A,B) or (B,A) with the
  // same key.
  playerAId   String
  playerBId   String
  // Winner is one of playerAId or playerBId (enforced in app code,
  // not at DB level — keep schema simple).
  winnerId    String
  recordedAt  DateTime @default(now())
  // Discord ID of the admin/helper who recorded via /admin command,
  // OR "self-report" if a player used /report-shootout.
  recordedBy  String
  notes       String?

  @@unique([divisionId, playerAId, playerBId])
  @@index([divisionId])
}

enum DivisionMemberStatus {
  ACTIVE
  DROPPED   // quit mid-season; existing pairings stay, unplayed ones become forfeits at admin's option
}

model DivisionMember {
  id            String              @id @default(cuid())
  divisionId    String
  // Denormalized from Division.seasonId so we can enforce one-member-per-
  // season-per-player at the DB layer via @@unique([seasonId, playerId]).
  // Kept in sync by placePlayerInDivision (the only write path).
  seasonId      String
  playerId      String
  joinedAt      DateTime            @default(now())
  status        DivisionMemberStatus @default(ACTIVE)
  droppedAt     DateTime?
  dropoutReason String?
  // Snapshot of Player.rating at the moment the season was BUILT —
  // i.e. the "seed" rank admin set during the drag/sort/build flow.
  // Frozen in time per-season so we can show "entered at #N, finished
  // at #M" in profile / standings without confusing the live
  // Player.rating with the as-of-build snapshot.
  seedRank Int?
  // Snapshot of Player.rating (= global rank) at end-of-season. Written by
  // endSeason for each ACTIVE member at the same moment Player.rating is
  // updated. Lets us answer "what was X's global rank when Season 4
  // ended" without losing the history when Season 5 rewrites the same
  // Player.rating field. Null until that season's endSeason runs.
  finalGlobalRank Int?
  // Per-division ordering during draft mode. Admin drags rows between
  // and within division cards on /admin/seasons/[id]; this is the
  // tiebreaker that determines the display + drop position. After a
  // season activates, this field is functionally inert — round-robin
  // standings don't care about the seed order — but it's still set so
  // re-opening the draft view (e.g., for an unended season) keeps the
  // last-known shape. Defaults to 0; rebalanced per-division on every
  // positional move.
  draftOrder    Int                 @default(0)

  division      Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([divisionId, playerId])
  // Hard guarantee: a player can be in at most one division per season.
  @@unique([seasonId, playerId])
  @@index([playerId])
  @@index([divisionId, status])
}

enum PairingStatus {
  PENDING    // submitted by reporter, awaiting opponent confirm
  CONFIRMED  // opponent confirmed OR admin force-resolved → counts in standings
  DISPUTED   // opponent rejected → needs admin attention
  CANCELLED  // admin voided
}

// A 2-game series between two players within a Division. Exactly one row per unordered pair.
model Pairing {
  id           String        @id @default(cuid())
  divisionId   String
  playerAId    String        // canonical: playerA.id < playerB.id (lexicographic) so the pair is unique
  playerBId    String
  // Games won by A and by B across the 2-game series. Together they sum to 2 (or 0 if not yet reported).
  gamesWonA    Int           @default(0)
  gamesWonB    Int           @default(0)
  status       PairingStatus @default(PENDING)
  reporterId   String?       // which player submitted /report
  reportedAt   DateTime?
  confirmedAt  DateTime?
  // If status=CONFIRMED via admin override, who and why
  adminOverrideBy String?
  adminOverrideReason String?
  // Where the public report embed was posted (Discord IDs). Populated
  // when /report or the web report submits and triggers a #results
  // post; used by the 2-min auto-confirm cron + Confirm/Dispute buttons
  // to edit the original embed in place.
  reportChannelId String?
  reportMessageId String?

  // Dispute details. All null for non-disputed pairings.
  //   disputedById             — which player initiated the dispute
  //   disputeProposedGamesWonA/B — what the disputer says it should be.
  //                              Null if disputed without a proposed
  //                              correction (legacy Discord-button path).
  //                              Admin can one-click accept the proposal
  //                              via /admin/disputes.
  //   disputeReason            — free-text explanation, optional
  //   disputedAt               — when the dispute was filed (NOT
  //                              cleared on resolution; persists for audit)
  //   disputeThreadId          — Discord thread spawned for helper
  //                              mediation. Set after spawn so we don't
  //                              double-create on re-dispute.
  disputedById              String?
  disputeProposedGamesWonA  Int?
  disputeProposedGamesWonB  Int?
  disputeReason             String?
  disputedAt                DateTime?
  disputeThreadId           String?

  // True if AT LEAST one of the games in this pairing was forfeited via
  // the opponent-DC button instead of a normal winner vote. Doesn't
  // affect standings math (a DC-win still scores 2-0 the same way) —
  // surfaced on history/admin views so audit can spot serial DC'ers.
  // Per-game DC attribution lives in the MatchSession GameState JSON.
  hadDc                     Boolean       @default(false)

  division     Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  playerA      Player   @relation("PairingPlayerA", fields: [playerAId], references: [id])
  playerB      Player   @relation("PairingPlayerB", fields: [playerBId], references: [id])
  reporter     Player?  @relation("PairingReporter", fields: [reporterId], references: [id])
  disputer     Player?  @relation("PairingDisputer", fields: [disputedById], references: [id])

  @@unique([divisionId, playerAId, playerBId])
  @@index([divisionId, status])
}

// Named bundle of league rules: scoring + ban policy + timeouts.
// Replaces the legacy per-key LeagueConfig values for these fields.
// Exactly one row has isDefault=true at any time — that's the one used
// when a season hasn't picked a specific template (and the one
// /admin/settings edits "for everyone"). Admin can create alternates
// (e.g. "Casual Rules", "Strict 2-Ban") and pick per season on the
// season detail page.
model LeagueRulesTemplate {
  id                       String   @id @default(cuid())
  name                     String   @unique
  isDefault                Boolean  @default(false)

  // Timeouts. Scoring (3/1/0) and ban/pick policy (4/3/9/2) are
  // hardcoded constants in web/lib/league-settings.ts — not stored
  // per-template.
  matchInviteExpiryMinutes Int      @default(5)
  reportAutoConfirmSeconds Int      @default(120)

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  seasons                  Season[]

  @@index([isDefault])
}

// Append-only audit log of admin actions + key system events. Read by
// /admin/audit. Never mutated after insert (no updatedAt). Both the bot
// (via src/audit.ts) and the web app (via web/lib/audit.ts) call
// recordAudit() to write rows.
//
// action: dot-separated canonical key, e.g.
//   match.override, match.cancel-admin, match.cancel-player,
//   season.create, season.end, season.build,
//   role.strip, role.award-champion,
//   config.set, role-binding.set,
//   pairing.undo, pairing.record, shootout.record,
//   signup-round.open, signup-round.close,
//   match.start, match.complete
// actor* describes who took the action. For system events that don't
// have a human actor (cron jobs, auto-confirms) actorDiscordId is the
// literal string "system" and actorName the job name.
model AdminAuditEvent {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  actorDiscordId  String
  actorName       String
  action          String
  targetType      String?  // "MatchSession" | "Season" | "Pairing" | "Player" | "LeagueConfig" | ...
  targetId        String?
  summary         String   // one-line human description
  metadata        Json?    // structured payload — reason, before/after snapshots, etc.

  @@index([createdAt])
  @@index([actorDiscordId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}
