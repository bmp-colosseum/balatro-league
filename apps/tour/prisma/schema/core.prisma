// match-core — shared schema FRAGMENT for the 1v1 match engine.
//
// This file has NO generator/datasource on purpose: it's merged into each
// consuming app's `prisma/` folder (Prisma multi-file schema) alongside that
// app's own `app.prisma`, which supplies the generator + datasource. A sync
// step copies this file into each app's prisma folder.
//
// Design rule: these models are COMPETITION-AGNOSTIC. A `Match` knows its two
// players, its games, and its result — NOT what division/set/week it belongs
// to. The host app links a Match from its own side (e.g. Tour's `TourSet.matchId`).
// (Extracted from the league schema; `divisionId` removed.)

enum MatchStatus {
  PENDING // submitted by reporter, awaiting opponent confirm
  CONFIRMED // opponent confirmed OR admin force-resolved
  DISPUTED // opponent rejected → needs attention
  CANCELLED // voided
}

model Player {
  id                   String   @id @default(cuid())
  discordId            String   @unique
  displayName          String
  hasCustomDisplayName Boolean  @default(false)
  createdAt            DateTime @default(now())

  matchesAsA      Match[] @relation("MatchPlayerA")
  matchesAsB      Match[] @relation("MatchPlayerB")
  reportedMatches Match[] @relation("MatchReporter")
  disputedMatches Match[] @relation("MatchDisputer")
}

// Named bundle of decks + stakes (the pool a match's ban/pick draws from).
// White-stake + a deck list = one preset. The NAME carries no meaning.
model MatchConfigPreset {
  id        String   @id @default(cuid())
  name      String   @unique
  decks     String[]
  stakes    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Guided ban/pick session driven by the bot in a Discord thread.
enum MatchSessionState {
  WAITING_ACCEPT
  GAME_1_BAN
  GAME_1_PICK
  GAME_1_PLAYING
  GAME_2_CHOOSE_FIRST
  GAME_2_BAN
  GAME_2_PICK
  GAME_2_PLAYING
  GAME_3_CHOOSE_FIRST
  GAME_3_BAN
  GAME_3_PICK
  GAME_3_PLAYING
  PAUSED
  COMPLETE
  CANCELLED
}

model MatchSession {
  id                      String            @id @default(cuid())
  playerAId               String
  playerBId               String
  state                   MatchSessionState @default(WAITING_ACCEPT)
  pausedFromState         MatchSessionState?
  pauseInitiatorPlayerId  String?
  resumeInitiatorPlayerId String?
  pausedAt                DateTime?
  cancelInitiatorPlayerId String?
  cancelInitiatedAt       DateTime?
  dcInitiatorPlayerId     String?
  version                 Int               @default(0)
  // Casual/no-record session (no Match written at COMPLETE).
  isCasual                Boolean           @default(false)
  // 1..N — how many games (best-of). Variable per session.
  bestOf                  Int               @default(2)
  // 1-game tiebreaker flag.
  isShootout              Boolean           @default(false)
  threadId                String?
  channelId               String?
  matchMessageId          String?
  helperCalledAt          DateTime?
  // JSON blobs so state shape can evolve without migrations.
  pool                String?
  policy              String?
  customCombo         String?
  customComboProposal String?
  game1               String?
  game2               String?
  game3               String?
  // Set when COMPLETE → the written Match. (Host app interprets context.)
  matchId             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @default(now()) @updatedAt
  expiresAt           DateTime?
  acceptedAt          DateTime?
  completedAt         DateTime?
  threadArchivedAt    DateTime?

  @@index([state])
  @@index([state, updatedAt])
  @@index([threadId])
  @@index([state, expiresAt])
  @@index([state, threadArchivedAt])
}

// A played series between two players — the durable record. Competition-agnostic:
// no division/set FK. The host app links it (e.g. TourSet.matchId @unique).
// `format` is a free string (e.g. "BO2", "BO3", "BO5", "SHOOTOUT_BO1") so apps
// aren't coupled to a shared enum.
model Match {
  id                       String      @id @default(cuid())
  playerAId                String // canonical: playerA.id < playerB.id
  playerBId                String
  format                   String      @default("BO2")
  gamesWonA                Int         @default(0)
  gamesWonB                Int         @default(0)
  winnerId                 String? // one of A/B; null for a draw
  status                   MatchStatus @default(PENDING)
  reporterId               String?
  reportedAt               DateTime?
  confirmedAt              DateTime?
  adminOverrideBy          String?
  adminOverrideReason      String?
  reportChannelId          String?
  reportMessageId          String?
  disputedById             String?
  disputeProposedGamesWonA Int?
  disputeProposedGamesWonB Int?
  disputeReason            String?
  disputedAt               DateTime?
  disputeThreadId          String?
  hadDc                    Boolean     @default(false)
  forfeit                  Boolean     @default(false)
  forfeitReason            String?
  reportedDeck             String?
  reportedStake            String?
  recordedBy               String?
  notes                    String?
  createdAt                DateTime    @default(now())

  playerA  Player  @relation("MatchPlayerA", fields: [playerAId], references: [id])
  playerB  Player  @relation("MatchPlayerB", fields: [playerBId], references: [id])
  reporter Player? @relation("MatchReporter", fields: [reporterId], references: [id])
  disputer Player? @relation("MatchDisputer", fields: [disputedById], references: [id])
  games    Game[]

  @@index([playerAId])
  @@index([playerBId])
  @@index([status])
}

// One game within a Match. Carries the deck+stake it was played on, the winner,
// the winner's remaining lives (attrition), and per-game ban/pick flags.
model Game {
  id                  String  @id @default(cuid())
  matchId             String
  num                 Int
  firstPlayerId       String
  winnerId            String?
  winnerLives         Int? // 1..N remaining for winnerId; null if not captured
  deck                String
  stake               String
  dcByPlayerId        String?
  pickedRandomly      Boolean @default(false)
  firstBannedRandomly Boolean @default(false)
  otherBannedRandomly Boolean @default(false)

  match Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  pool  GameDeck[]

  @@unique([matchId, num])
  @@index([matchId])
  @@index([deck])
  @@index([stake])
}

// One combo in a Game's pool (full pool, one row per combo) — picked / banned /
// survivor — so deck/stake/ban stats are exact SQL aggregates.
model GameDeck {
  id         String  @id @default(cuid())
  gameId     String
  poolIdx    Int
  deck       String
  stake      String
  picked     Boolean @default(false)
  banOrdinal Int?
  bannedById String?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, poolIdx])
  @@index([gameId])
  @@index([deck])
  @@index([stake])
}
