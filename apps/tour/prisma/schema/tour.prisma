// Team Tour app schema. Merged with `core.prisma` (the shared match engine) via
// Prisma's multi-file schema folder. The generator + datasource live here; the
// core fragment has none.
//
// Decoupling rule (design §0-A): Tour models reference core `Player`/`Match` by
// PLAIN ID STRING (e.g. captainPlayerId, TourSet.matchId) — NOT a Prisma
// relation — so `core.prisma` carries no Tour-specific back-relations and stays
// reusable. App code joins by id. Relations are only used WITHIN the Tour models.

generator client {
  provider = "prisma-client-js"
  // Custom output so the Tour client never clobbers the league's default
  // node_modules/@prisma/client (different schema, shared workspace).
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────
enum TourSeasonState {
  SIGNUPS
  SIGNUPS_CLOSED // pool locked; committee reviews, sets structure, builds teams
  DRAFTING
  REGULAR
  PLAYOFFS
  DONE
}

// The competition format varies by season (the framework is format-agnostic —
// competition-core treats each as config). SWISS = one pool ranked by the chain;
// CONFERENCES = N groups, round-robin within, top-K each into the bracket.
enum SeasonFormat {
  SWISS
  CONFERENCES
}

enum WeekKind {
  ROUND_ROBIN
  RIVAL // week vs the captain-chosen pre-draft rival
  CROSS_CONF // random cross-conference week
  SEEDED // final regular week: #1 vs #last, mirrored
  PLAYOFF
}

enum SetStatus {
  PROPOSED // pairing created, not scheduled
  SCHEDULED
  REPORTED // result in, awaiting both-player confirm
  CONFIRMED
  DISPUTED
  FORFEIT
}

enum DraftState {
  PENDING
  ACTIVE
  DONE
}

enum SignupStatus {
  PENDING // submitted, awaiting committee review
  APPROVED // in the draft pool
  REJECTED // not admitted this season
  WITHDRAWN // player pulled out
}

enum PlayoffRound {
  ROUND_OF_64
  ROUND_OF_32
  ROUND_OF_16
  QUARTERFINAL
  SEMIFINAL
  FINAL
}

// Roster-change log kinds (§B7 / weekly roster model). Every change to a team's
// lineup is an append-only RosterMove; the active lineup for any week is DERIVED
// by folding the log (derive-on-read). Nothing is ever deleted → full history.
enum RosterMoveKind {
  DRAFTED // initial slot from the draft (effectiveWeek = 1)
  ADDED // permanent addition / replacement arrival into a slot
  SUB // temporary fill-in covering [effectiveWeek, untilWeek]
  QUIT // voluntary permanent departure from effectiveWeek
  BANNED // disciplinary permanent departure (ban / DQ) from effectiveWeek
  REINSTATED // reverses a prior QUIT/BANNED from effectiveWeek
  CAPTAIN_CHANGE // captaincy passes to playerId (replacesPlayerId = the old captain)
  RESEED // playerId's intra-team seed changes to `seed` from effectiveWeek
}

// A recorded reliability/conduct mark against a player (§Sportsmanship + Scheduling).
// Per the rules these are TO-discretion AIDS — they inform the TO, they do NOT
// auto-penalize. Career-spanning (seasonId optional) with a per-season breakdown.
enum StrikeKind {
  SCHEDULING // no reasonable effort to schedule / chronically late
  NO_SHOW // didn't show for a scheduled set
  CONDUCT // sportsmanship / behaviour
  OTHER
}

enum AwardKind {
  MVP
  ROOKIE
  COMEBACK
  CAPTAIN
  MOST_IMPROVED
  BEST_SET
  BIGGEST_STEAL
}

// Web/admin permission tiers, bound to Discord roles via RoleBinding (mirrors the
// league). The web fetches a user's guild roles and resolves the highest tier.
enum PermissionTier {
  OWNER // full power, incl. destructive ops + role binding
  TO // tournament organizer: season/draft/schedule/dispute management
  HELPER // mediation: join set channels, record verbal results
  DEVOPS // infra alerts only — NOT a TO power (separate surface)
}

// ── Season-spanning identity ───────────────────────────────────────────────
// (Player lives in core.prisma — referenced by id everywhere here.)
model Team {
  id          String       @id @default(cuid())
  name        String       @unique // season-spanning identity by name
  createdAt   DateTime     @default(now())
  teamSeasons TeamSeason[]
}

// ── Per-season competition ─────────────────────────────────────────────────
model TourSeason {
  id            String          @id @default(cuid())
  name          String          @unique
  teamSize      Int // 7 or 9 (or whatever a season runs)
  setsToWin     Int // majority — 4 of 7, 5 of 9
  defaultBestOf Int             @default(3) // per-set default; players may agree higher
  format        SeasonFormat    @default(CONFERENCES) // SWISS or CONFERENCES (varies by season)
  conferenceCount Int           @default(2) // for CONFERENCES; top-(playoffTeams/count) each
  playoffTeams  Int             @default(8) // bracket field size (8 → 4 → 2)
  state         TourSeasonState @default(SIGNUPS)
  createdAt     DateTime        @default(now())
  // Bot-managed Discord roles for this season (set when the bot provisions them).
  // The bot syncs membership from the roster: every rostered player gets
  // playerRoleId; captains also get captainRoleId (→ captain-only channels).
  // Authorization source of truth stays the DATA (RosterEntry / captainPlayerId);
  // these roles are for Discord channel access + visibility.
  playerRoleId  String?
  captainRoleId String?

  conferences Conference[]
  teamSeasons TeamSeason[]
  weeks       Week[]
  draft       Draft?
  signups     Signup[]
  scheduleExclusions ScheduleExclusion[]
}

// An intentional non-matchup: two teams a season's schedule deliberately never pairs
// (e.g. TT4 ran a near-round-robin where one pair per conference didn't play). Lets the
// coverage grid tell a DESIGNED gap from a real hole -- excluded pairs render as a bye and
// don't count toward "missing", while every other blank is a game the TO still owes.
// Teams by plain id (decoupling rule); stored canonically (A id < B id) so the pair is
// order-independent and uniquely keyed.
model ScheduleExclusion {
  id            String   @id @default(cuid())
  seasonId      String
  teamSeasonAId String
  teamSeasonBId String
  createdAt     DateTime @default(now())

  season TourSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, teamSeasonAId, teamSeasonBId])
}

model Conference {
  id       String     @id @default(cuid())
  seasonId String
  name     String // "Eris" / "Pluto" / … — varies per season

  season      TourSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamSeasons TeamSeason[]

  @@unique([seasonId, name])
}

// A team's entry in one season: its conference, captain, seed, and rival.
model TeamSeason {
  id             String  @id @default(cuid())
  seasonId       String
  teamId         String
  conferenceId   String
  captainPlayerId String // core Player.id (by id, no relation)
  seed           Int // team seed = captain's draft seed
  rivalTeamSeasonId String? // pre-draft chosen rival (Rival Week), by id

  season     TourSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team       Team         @relation(fields: [teamId], references: [id])
  conference Conference   @relation(fields: [conferenceId], references: [id])
  rosters    Roster[]

  @@unique([seasonId, teamId])
}

// Per-week-block lineup snapshot (subs / roster changes are versioned).
model Roster {
  id           String        @id @default(cuid())
  teamSeasonId String
  weekBlock    String // "W1-4" | "W5-8" | "PLAYOFFS"
  entries      RosterEntry[]

  teamSeason TeamSeason @relation(fields: [teamSeasonId], references: [id], onDelete: Cascade)

  @@unique([teamSeasonId, weekBlock])
}

model RosterEntry {
  id          String  @id @default(cuid())
  rosterId    String
  playerId    String // core Player.id
  seed        Int // intra-team seed (1..N = draft order)
  isCaptain   Boolean @default(false)
  isCoCaptain Boolean @default(false) // co-captain: same team-scoped powers as the captain (pairing, subs, reporting)

  roster Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, playerId])
}

// ── Weeks, matchups, sets ──────────────────────────────────────────────────
model Week {
  id         String    @id @default(cuid())
  seasonId   String
  number     Int
  kind       WeekKind
  opensAt    DateTime?
  deadlineAt DateTime? // sets must be PLAYED by here (Sun 23:59 ET — §12.1)

  season   TourSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  matchups Matchup[]

  @@unique([seasonId, number])
}

// One team-vs-team matchup in a week. N parallel TourSets; majority of set wins
// takes the matchup. teamSeason A/B referenced by id (no relation — keeps
// TeamSeason free of two noisy back-relations).
model Matchup {
  id                    String   @id @default(cuid())
  weekId                String
  teamSeasonAId         String
  teamSeasonBId         String
  sendFirstTeamSeasonId String? // coinflip winner (higher seed auto in playoffs)
  // Live two-captain pairing: the in-flight proposal awaiting the other captain's
  // response (cleared once they respond → a pair is persisted). Null = no proposal
  // pending. TO console doesn't use this (it does propose+respond atomically).
  pendingProposalPlayerId String?
  officialPlayerId      String? // assigned caster/official ("Advantages") — Phase 3
  // Team-level result. Derived from the matchup's TourSets in live play; stored
  // directly for imported team-only seasons (no per-set data).
  setsWonA           Int?
  setsWonB           Int?
  gamesWonA          Int?
  gamesWonB          Int?
  winnerTeamSeasonId String?

  week Week      @relation(fields: [weekId], references: [id], onDelete: Cascade)
  sets TourSet[]
}

// A single 1v1 best-of-X set inside a matchup. Wraps a core Match by id.
model TourSet {
  id          String    @id @default(cuid())
  matchupId   String? // null for historical/standalone imports (no matchup)
  seasonId    String? // direct season link when there's no matchup (historical)
  week        Int? // season week this set was played (for week-by-week rebuild)
  // The teamSeason each player represented in THIS set — lets a player be on a team by
  // virtue of having PLAYED (subs included), and lets us derive each team's week-by-week
  // lineup from results. By plain id (decoupling rule), no relation.
  teamSeasonAId String?
  teamSeasonBId String?
  bracket     String? // historical marker (e.g. "REGULAR" / playoff round)
  importKey   String?   @unique // idempotent import id, e.g. "gamelog:s1:42"
  matchId     String?   @unique // core Match.id (null until played; by id, no relation)
  playerAId   String // core Player.id (Team A's player, seed seedA)
  playerBId   String // core Player.id (within ±2 of seedA)
  seedA       Int
  seedB       Int
  bestOf      Int
  status      SetStatus @default(PROPOSED)
  scheduledAt DateTime?
  // When a substitute is assigned to an UNPLAYED set (e.g. a late "makeup" set the
  // originally-paired player can no longer play because they dropped out), the slot's
  // player (playerAId/playerBId) is reassigned and the original is remembered here.
  // playerAId/B always = who actually plays → stats credit them; this is the audit.
  reassignedFromId String?

  matchup Matchup? @relation(fields: [matchupId], references: [id], onDelete: Cascade)

  @@index([seasonId])
}

// ── Signups (the draft pool) ───────────────────────────────────────────────
// Hybrid signup (§14.2): players self-serve via Discord OAuth + form; committee
// curates by moving PENDING → APPROVED. The set of APPROVED signups IS the draft
// pool that DraftPick.playerId draws from. Availability is a SOFT helper only
// (§14.4) — people mostly just DM each other — so it's coarse and nullable.
model Signup {
  id               String       @id @default(cuid())
  seasonId         String
  discordId        String // THE identity — captured at OAuth signup; no Player row needed yet.
  displayName      String? // snapshot from Discord at signup; display-only, the ID is the key.
  timezone         String? // IANA, e.g. "America/New_York" — powers the TO awkward-tz flag
  availability     String? // free-form / coarse general availability — a hint, not a schedule
  willingToCaptain Boolean      @default(false) // derived from captainInterest (kept for draft-pool queries)
  bmpHandle        String? // legacy — rank is now auto-pulled by discordId (bmpMmr/bmpTier)
  status           SignupStatus @default(PENDING)
  createdAt        DateTime     @default(now())

  // ── The real form (option labels stored verbatim — the wording is part of the culture) ──
  scheduleAgency  String? // "Yes, I have commitments..." / "Somewhat..." / "No, I do not have much control"
  playFrequency   String? // how often + how they play (single player, ranked, ...)
  teamActivity    String? // how active with the team (messaging, practice, voice)
  coachWilling    Boolean @default(false) // willing to coach
  coachWanted     Boolean @default(false) // willing to be coached
  coachingNote    String? // voice/mic/frequency note (optional)
  captainInterest String? // "Yes, I would love to!" / "I will if it is needed" / "Not interested"
  helperInterest  Boolean @default(false) // assistant TO — feeds the mod-grant pipeline
  englishOk       Boolean @default(true)
  discordActivity Int? // 1-10 ("once per day = 6")
  upcomingBreaks  String? // "No" / "Possibly" / "Yes"
  weeklyCommit    String? // Yes / Maybe / No — one Bo3 (2-3h) per week for 7-10 weeks
  outreach        String? // Yes / Maybe / No — reach out to opponents weekly
  modCheck        String? // Yes / Maybe / No — verify mod versions before sets
  respectPledge   String? // Yes / Maybe / No
  asyncExp        String? // "Yes, in a similar tournament to this" / "Yes, in other contexts" / "No"
  comments        String? // intro / self-nerfs — also the flavor text for their player card
  twitchFollow    String? // "Of course!" / "Yes, and I'll subscribe with Twitch Prime!" / "No, L self promo"

  // ── Auto-pulled (never asked) ──
  bmpMmr  Int? // Ranked MMR by discordId at (re)submit — balatromp tRPC
  bmpTier String? // derived tier label ("Gold", "Lucky", ...)

  season TourSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, discordId])
  @@index([seasonId, status])
}

// ── Draft ──────────────────────────────────────────────────────────────────
model Draft {
  id        String      @id @default(cuid())
  seasonId  String      @unique
  state     DraftState  @default(PENDING)
  orderJson String // JSON: teamSeason ids in snake order
  picks     DraftPick[]

  season TourSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}

model DraftPick {
  id           String    @id @default(cuid())
  draftId      String
  round        Int
  pickIndex    Int // overall pick number (seed within the team derives from this)
  teamSeasonId String
  playerId     String? // core Player.id (null until the pick is made)
  // Timing — NO enforced deadline (the draft is async; §14 / user call). These
  // power the "on the clock for 2h 14m" live timer + fun pick-duration stats.
  onClockAt    DateTime? // when this pick became the current one
  pickedAt     DateTime? // when the captain actually picked

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, pickIndex])
}

// ── Fantasy (ws08) — a meta-game over a live season ────────────────────────
// Managers draft real players; scoring derives on read from the season's sets via the
// pure core (packages/tour-core fantasy). All ids are plain (decoupling rule) — no FK to
// TourSeason/Player/TeamSeason — so deleteSeason clears FantasyLeague explicitly.
enum FantasyScope {
  SEASON // every set all season scores
  PLAYOFFS // only playoff sets score — eliminated players are simply done (you can get screwed)
}

model FantasyLeague {
  id            String       @id @default(cuid())
  seasonId      String       @unique // TourSeason.id (plain id)
  scope         FantasyScope @default(SEASON)
  rosterSize    Int // players per fantasy roster (defaults to the real teamSize)
  setWinPoints  Int          @default(1)
  gameWinPoints Int          @default(1)
  tradesEnabled Boolean      @default(true)
  createdAt     DateTime     @default(now())

  // Live snake-draft lifecycle (derived state — no enum needed):
  //   draftStartedAt == null            -> OPEN (managers may still join)
  //   set, madePicks < rosterSize*teams -> DRAFTING
  //   madePicks == total                -> DONE
  draftStartedAt DateTime? // set once when the TO starts the draft (locks joins + order)
  orderJson      String? // JSON array of FantasyTeam.id in frozen snake seed order
  onClockSince   DateTime? // bumped each pick — powers the cosmetic ElapsedClock

  // Trades + weekly lock. lockedThroughWeek: weeks <= this are frozen/scored, so an APPLIED
  // trade always lands AFTER it (never reflows a scored week). tradeDeadlineWeek: once the
  // current week passes it, no NEW proposals (in-flight accepted trades still apply).
  tradeApproval     TradeApproval @default(AUTO)
  lockedThroughWeek Int           @default(0)
  tradeDeadlineWeek Int?

  teams  FantasyTeam[]
  trades FantasyTrade[]
}

model FantasyTeam {
  id               String @id @default(cuid())
  leagueId         String
  managerDiscordId String
  name             String

  joinOrder Int // 1-based claim order (cuid order is not a reliable snake seed)
  createdAt DateTime @default(now())

  league FantasyLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks  FantasyPick[]

  @@unique([leagueId, managerDiscordId])
}

model FantasyPick {
  id            String @id @default(cuid())
  fantasyTeamId String
  pickIndex     Int // overall snake-draft pick number
  playerId      String // core Player.id drafted
  teamSeasonId  String // the real team the player was on at draft (display + future sub-lineage)
  seed          Int // their intra-team seed at draft

  team FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)

  @@unique([fantasyTeamId, pickIndex])
  @@unique([fantasyTeamId, playerId])
}

// Whether a manager-accepted trade applies instantly (AUTO) or waits for a TO to approve.
enum TradeApproval {
  AUTO
  TO_APPROVED
}

enum FantasyTradeStatus {
  PROPOSED // proposer offered; awaiting the receiver
  TO_REVIEW // receiver accepted; awaiting a TO (TO_APPROVED leagues only)
  APPLIED // ownership transferred from effectiveWeek forward (terminal, the only scoring state)
  REJECTED // receiver declined
  CANCELLED // proposer withdrew
}

// A two-party fantasy trade AND the ownership log: standings fold APPLIED trades' items over
// the FantasyPick draft-owner base to resolve who owned a player at any week (derive-on-read,
// mirroring RosterMove). A trade never mutates FantasyPick (draft history + uniqueness stay intact).
model FantasyTrade {
  id                  String             @id @default(cuid())
  leagueId            String
  proposerTeamId      String // FantasyTeam.id offering
  receiverTeamId      String // FantasyTeam.id receiving the offer
  status              FantasyTradeStatus @default(PROPOSED)
  effectiveWeek       Int? // null until APPLIED; set to max(lockedThroughWeek, currentWeek)+1 at apply
  proposedByDiscordId String
  reason              String?
  createdAt           DateTime           @default(now())
  decidedAt           DateTime?

  league FantasyLeague      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  items  FantasyTradeItem[]

  @@index([leagueId])
  @@index([receiverTeamId])
  @@index([proposerTeamId])
}

// One player changing hands within a trade (N-for-M capable; MVP UI is 1-for-1). fromTeamId
// gives up ownership, toTeamId gains it, from the parent trade's effectiveWeek forward.
model FantasyTradeItem {
  id         String @id @default(cuid())
  tradeId    String
  playerId   String // real Player.id (must match a FantasyPick in this league)
  fromTeamId String // FantasyTeam.id giving up ownership
  toTeamId   String // FantasyTeam.id gaining ownership

  trade FantasyTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([playerId])
}

// ── Playoffs ───────────────────────────────────────────────────────────────
model PlayoffEntry {
  id           String  @id @default(cuid())
  seasonId     String
  teamSeasonId String
  seed         Int
  viaWildcard  Boolean @default(false)

  @@unique([seasonId, teamSeasonId])
}

model PlayoffSeries {
  id                 String       @id @default(cuid())
  seasonId           String
  round              PlayoffRound
  bracketIndex       Int          @default(0) // position within its round (bracket order) — drives advanceWinners
  conferenceId       String? // which conference's bracket this series is in (null = cross-conference FINAL); plain id, no relation
  teamSeasonAId      String? // higher seed (for historical champion-path imports, A = the champion)
  teamSeasonBId      String? // the opponent
  scoreA             Int? // set score (A's sets won)
  scoreB             Int?
  winnerTeamSeasonId String?
  matchupId          String? // the Matchup that plays out this series (live seasons)

  @@index([seasonId])
}

// ── Cross-season (Hall of Fame / rings / awards) ───────────────────────────
model Championship {
  id        String   @id @default(cuid())
  seasonId  String
  teamId    String // the winning Team (season-spanning)
  createdAt DateTime @default(now())
}

// An award (preset kind or a custom title) with one OR MORE recipient slots. `kind` is a preset
// (the 7 well-known kinds) or null for a fully custom award; `title` overrides the kind label.
// Recipients live in AwardRecipient. Legacy playerId/teamId/meta are kept ONLY for imported
// single-recipient awards (parse-awards.mjs writes them); new awards write AwardRecipient rows and
// the read models fold recipients-else-legacy, so imports render without a data migration.
model Award {
  id          String           @id @default(cuid())
  seasonId    String
  kind        AwardKind? // preset kind, or null for a custom (title-only) award
  title       String? // custom title; overrides the preset kind label when set
  description String? // optional blurb shown under the title
  sortIndex   Int              @default(0)
  playerId    String? // LEGACY single recipient (imports) — core Player.id
  teamId      String? // LEGACY single recipient (imports)
  meta        Json? // e.g. Best-Set = the set; Biggest-Steal = draft pick #; legacy team name
  recipients  AwardRecipient[]

  @@index([seasonId])
}

// One recipient slot of an Award: a player XOR a team, with an optional per-slot note
// ("1st team", "Finals MVP", ...). Cascade-deleted with its award.
model AwardRecipient {
  id        String  @id @default(cuid())
  awardId   String
  playerId  String? // core Player.id (player slot)
  teamId    String? // Team.id (team slot)
  note      String? // optional per-slot note
  sortIndex Int     @default(0)
  award     Award   @relation(fields: [awardId], references: [id], onDelete: Cascade)

  @@index([awardId])
  @@index([playerId])
}

// Imported career counters from the cross-season `Player Stats` sheet — the ones
// we can't derive from our (champion-path-only) playoff data: avg seed, and
// championships / finals / playoffs MADE. Keyed by core Player.id, one per player.
model PlayerCareerStat {
  id            String  @id @default(cuid())
  playerId      String  @unique // core Player.id
  avgSeed       Float?
  rookieSeason  Int?
  championships Int     @default(0)
  finalsMade    Int     @default(0)
  playoffsMade  Int     @default(0)
  everCaptain   Boolean @default(false)
}

// ── Roster moves — the weekly roster change log (§B7 + D2 timeline) ─────────
// One append-only row per change. The active lineup for any week is DERIVED by
// folding these (see lib/services/roster-ops.ts rosterForWeek); the timeline is
// the log itself. Players/teams referenced by id (decoupling rule). Membership
// for stat attribution lives in RosterEntry; this layer is lineup-over-time.
model RosterMove {
  id               String         @id @default(cuid())
  seasonId         String
  teamSeasonId     String
  playerId         String // the player this move concerns (SUB: the one coming IN)
  outPlayerId      String? // SUB: the player going OUT for the covered weeks
  replacesPlayerId String? // ADDED: the departed player whose slot this fills
  kind             RosterMoveKind
  effectiveWeek    Int // schedule week number this takes effect
  untilWeek        Int? // SUB: last covered week (null = single week)
  seed             Int? // DRAFTED/ADDED: the intra-team seed slot
  reason           String?
  createdBy        String? // admin discord id / name
  createdAt        DateTime       @default(now())

  @@index([seasonId])
  @@index([teamSeasonId])
}

// ── Roster change requests — captain-initiated ops awaiting mod approval ────
// Captains don't mutate the roster directly: their ops land here as PENDING
// requests. A mod (TO or ROSTERS grant) approves -> the matching roster-ops
// service fn runs (appending the real RosterMove), or rejects. Mods themselves
// skip this and apply directly. Payload is a superset of the roster-ops args;
// only the fields a given `kind` needs are set. Players/teams by id (decoupling).
enum RosterRequestKind {
  SUB
  QUIT
  BANNED
  REPLACE
  RESEED
  SWAP
  CAPTAIN_CHANGE
  CO_CAPTAIN
  REINSTATE
}

enum RosterRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model RosterChangeRequest {
  id               String              @id @default(cuid())
  seasonId         String
  teamSeasonId     String
  kind             RosterRequestKind
  playerId         String // primary subject (SUB/REPLACE in-player, RESEED/SWAP A, departing, new captain, reinstated, co-captain target)
  outPlayerId      String? // SUB: who comes out
  replacesPlayerId String? // REPLACE: the departed slot being filled
  playerBId        String? // SWAP: the second player
  effectiveWeek    Int
  untilWeek        Int? // SUB: last covered week
  seed             Int? // RESEED: the new seed
  isCoCaptain      Boolean? // CO_CAPTAIN: grant (true) or revoke (false)
  reason           String?
  status           RosterRequestStatus @default(PENDING)
  requestedBy      String // captain discord id / name
  requestedName    String?
  decidedBy        String? // approving/rejecting mod
  decidedAt        DateTime?
  decisionNote     String?
  createdAt        DateTime            @default(now())

  @@index([seasonId, status])
  @@index([teamSeasonId, status])
}

// Name -> Discord id reference (from the uploaded league CSV), for LINKING Tour
// players to a real Discord id when the live league DB isn't connected. Holds multiple
// name rows per person (display name + @username). The live league DB and the Tour
// Discord guild roster are read directly (not stored here) as additional id sources.
model LeagueRef {
  id        String @id @default(cuid())
  discordId String
  name      String
  source    String @default("league") // provenance (currently always "league")

  @@unique([discordId, name])
  @@index([name])
  @@index([discordId])
}

// Raw signup handle: a spreadsheet "preferred name" ↔ the Discord @username the
// person typed. Stored UNRESOLVED so it re-resolves live against the current id
// sources (LeagueRef league + Discord guild rows) — no re-import needed when a new
// id source (e.g. a Discord member sync) arrives. The chain preferred name →
// @username → numeric id is what auto-links most historical players.
model SignupRef {
  id            String @id @default(cuid())
  preferredName String
  username      String

  @@unique([preferredName, username])
  @@index([username])
}

// Reliability/conduct strikes — append-only, TO-issued. Informational (the TO
// decides consequences case-by-case); surfaced as a count + an "at risk" flag on
// admin views and a gentle heads-up to the player. Player/season referenced by id.
model Strike {
  id        String     @id @default(cuid())
  playerId  String // core Player.id
  seasonId  String? // the season it occurred in (career view aggregates across)
  week      Int? // optional week number
  kind      StrikeKind @default(SCHEDULING)
  reason    String
  issuedBy  String? // TO discord id / name
  createdAt DateTime   @default(now())

  @@index([playerId])
  @@index([seasonId])
}

// ── Web/admin permissions (Discord-role-driven, mirrors the league) ─────────
// A Discord role (in the Tour's own guild) → a permission tier. The web fetches
// the logged-in user's guild roles and resolves their highest tier; OWNER is also
// env-pinnable. Captain/player access is NOT here — that's competition data
// (TeamSeason.captainPlayerId / RosterEntry), with the bot mirroring it to the
// cosmetic Discord roles on TourSeason for channel access.
model RoleBinding {
  id            String         @id @default(cuid())
  discordRoleId String         @unique
  tier          PermissionTier
  createdAt     DateTime       @default(now())
  createdBy     String? // discord user id of who bound it

  @@index([tier])
}

// ── Site/bot configuration (key/value — league LeagueConfig pattern) ────────
// Channel ids for the bot (channel.results, channel.draft, channel.announcements),
// the slash-command registration hash (bot.commandHash), and future knobs. Editable
// at /admin/config; the bot reads via /api/bot/config.
model TourConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Fine-grained mod capabilities ───────────────────────────────────────────
// A TO delegates a slice of their power (news, rankings, rosters, draft, schedule) to a
// specific Discord USER or a Discord ROLE, optionally scoped to one season. Layered ON TOP
// of the tier system: OWNER/TO always have every capability; these grants let non-TOs do a
// specific job. Captain authority is data-derived (TeamSeason.captainPlayerId), not a grant.
enum Capability {
  NEWS
  RANKINGS
  ROSTERS
  DRAFT
  SCHEDULE
}

enum GrantSubject {
  USER
  ROLE
}

model ModGrant {
  id          String       @id @default(cuid())
  subjectType GrantSubject // USER = a Discord user, ROLE = a guild role
  subjectId   String // discordId (USER) | discordRoleId (ROLE)
  capability  Capability
  seasonId    String? // null = all seasons; set = that season only
  label       String? // cached username / role name for the admin list
  createdBy   String? // granter's discordId (audit)
  createdAt   DateTime     @default(now())

  @@unique([subjectType, subjectId, capability, seasonId])
  @@index([subjectId])
}

// ── Team Tour News Network ──────────────────────────────────────────────────
// Editorial posts (previews / recaps / power rankings) tied to a season and,
// optionally, a specific week. Body is free text (pasted from Discord), rendered
// with its line breaks preserved. seasonId is a plain id (like captainPlayerId).
model NewsPost {
  id        String   @id @default(cuid())
  seasonId  String
  week      Int? // optional — a week-specific preview/recap
  title     String
  body      String // free text; line breaks preserved on render
  createdBy String? // author (discord id / name)
  postedAt  DateTime @default(now()) // display/sort date; settable so archival posts keep their original date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonId])
}

// ── Power rankings (team or player) ─────────────────────────────────────────
// An ordered, optionally-tiered list ranking teams or players, attributed to an
// author (free text + optional player link), tagged to a season and week.
enum PowerRankingKind {
  TEAM
  PLAYER
}

model PowerRanking {
  id             String              @id @default(cuid())
  seasonId       String
  week           Int? // optional — a week's rankings
  kind           PowerRankingKind
  title          String
  author         String? // free-text attribution ("Team Tour News Network", a person's name)
  authorPlayerId String? // optional link to the ranker's player profile
  postedAt       DateTime            @default(now()) // display/sort date; settable for archival rankings
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  entries        PowerRankingEntry[]

  @@index([seasonId])
}

model PowerRankingEntry {
  id           String  @id @default(cuid())
  rankingId    String
  position     Int // 1..N
  tier         String? // "S" / "A" / "1" etc. (optional)
  teamSeasonId String? // for TEAM rankings
  playerId     String? // for PLAYER rankings
  note         String? // optional blurb

  ranking PowerRanking @relation(fields: [rankingId], references: [id], onDelete: Cascade)

  @@index([rankingId])
}

// ── Pick'em — per-set predictions by any signed-in user ─────────────────────
// One row per (predictor, set). A predictor is identified by their Discord id (they need
// not be a rostered Player — spectators can play too); name is cached for the leaderboard.
// Correctness is DERIVED on read: pickedPlayerId == the set's Match.winnerId. Picks are only
// accepted while the set is undecided; a decided set locks the pick.
model Prediction {
  id                 String   @id @default(cuid())
  seasonId           String
  setId              String // TourSet.id being predicted
  predictorDiscordId String
  predictorName      String? // cached display name for the leaderboard
  pickedPlayerId     String // the player predicted to win the set
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([predictorDiscordId, setId])
  @@index([seasonId])
  @@index([setId])
}
