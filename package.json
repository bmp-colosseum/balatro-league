{
  "name": "balatro-league",
  "version": "0.1.0",
  "description": "Discord bot that runs a Balatro league with round-robin divisions and promotion/relegation.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "register": "tsx src/scripts/register-commands.ts",
    "seed:test": "tsx src/scripts/seed-test.ts",
    "seed:test-league": "tsx src/scripts/seed-test-league.ts",
    "seed:returners-from": "tsx src/scripts/seed-returners-from.ts",
    "sim:season": "tsx src/scripts/sim-season.ts",
    "finish:season": "tsx src/scripts/finish-season.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "pg-boss": "^12.18.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
