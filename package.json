{
  "name": "balatro-league",
  "version": "0.1.0",
  "description": "Discord bot that runs a Balatro league with round-robin divisions and promotion/relegation.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "prisma migrate deploy && node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "register": "tsx src/scripts/register-commands.ts",
    "seed:test": "tsx src/scripts/seed-test.ts",
    "seed:test-matches": "tsx src/scripts/seed-test-matches.ts",
    "seed:e2e": "tsx src/scripts/seed-e2e.ts",
    "export:full": "tsx src/scripts/export-full.ts",
    "import:full": "tsx src/scripts/import-full.ts",
    "backup:db": "tsx src/scripts/backup-db.ts",
    "backup:bucket": "tsx src/scripts/backup-to-bucket.ts",
    "seed:returners-from": "tsx src/scripts/seed-returners-from.ts",
    "finish:season": "tsx src/scripts/finish-season.ts",
    "wipe:test-env": "tsx src/scripts/wipe-test-env.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@prisma/client": "^6.0.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "pg-boss": "^12.18.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "embedded-postgres": "^18.4.0-beta.17",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
