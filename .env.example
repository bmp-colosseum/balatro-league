# Copy this file to .env and fill in real values. Never commit .env.

# From https://discord.com/developers/applications → your app → Bot → Token
DISCORD_TOKEN=

# From the same page → General Information → Application ID
DISCORD_CLIENT_ID=

# Your Discord server (guild) ID — right-click the server icon → "Copy Server ID"
# (Enable Developer Mode in Discord settings first.)
# Commands register per-guild during dev (instant rollout). Leave blank for global registration.
DISCORD_GUILD_ID=

# Discord role ID that grants league-admin commands (e.g. /league force-result, end-season)
# Right-click the role in Server Settings → Roles → "Copy Role ID"
LEAGUE_ADMIN_ROLE_ID=

# Discord USER ID of the league owner — gets access to /admin commands without needing a role.
# Use yours for testing. Once the full permissions system is built, this becomes a fallback.
LEAGUE_OWNER_DISCORD_ID=

# Channel ID where the bot will post confirmed results & pinned standings
RESULTS_CHANNEL_ID=

# SQLite for dev. For production swap to a Postgres connection string:
# DATABASE_URL="postgresql://user:pass@host:5432/balatro_league"
DATABASE_URL="file:./dev.db"

# Web admin dashboard
WEB_PORT=3000
# Set this in real deployments. If unset, dashboard requires no login (fine for localhost dev).
ADMIN_DASH_PASSWORD=

# Discord OAuth (for player login + optional admin login)
# Reset/copy at https://discord.com/developers/applications → your app → OAuth2 → Client Secret
DISCORD_CLIENT_SECRET=
# Defaults to http://localhost:<WEB_PORT>/auth/discord/callback. Override in production.
DISCORD_OAUTH_REDIRECT=
# Session cookie signing key — generate fresh for production with: openssl rand -hex 32
SESSION_SECRET=change-this-in-prod-localhost-only
