# Template for the sops-encrypted secrets.yaml consumed by configuration.nix.
# Create the real, ENCRYPTED file with:
#   cp secrets.yaml.example secrets.yaml
#   sops secrets.yaml        # edit values, sops encrypts on save
# secrets.yaml (encrypted) is committed; this .example is plaintext guidance.

# GitHub Actions runner registration token (repo Settings -> Actions -> Runners
# -> New self-hosted runner) OR a fine-grained PAT with repo admin the module
# can use to self-register.
github-runner-token: "REPLACE_runner_token_or_pat"
