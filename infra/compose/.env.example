# Balatro League - compose secrets + config.
#
# Copy to the box as /srv/balatro/secrets.env, fill in real values, and keep it
# OFF git (it holds every secret). The deploy merges it with versions.env:
#   docker compose --env-file versions.env --env-file /srv/balatro/secrets.env up -d
#
# Want it version-controlled? sops-encrypt this file and decrypt to
# /srv/balatro/secrets.env on deploy (see infra/README.md).

# ---- domains (already what the code expects) --------------------------------
LEAGUE_DOMAIN=balatroleague.com
LEAGUE_WWW_DOMAIN=www.balatroleague.com
TOUR_DOMAIN=tour.balatroleague.com
AUTH_COOKIE_DOMAIN=.balatroleague.com
ACME_EMAIL=michaelpatrickharkins@gmail.com

# ---- Postgres ---------------------------------------------------------------
# Superuser + one password per app role (initdb/01-init.sh creates the roles).
# Use alphanumeric passwords (they are interpolated into DATABASE_URLs + SQL).
POSTGRES_PASSWORD=CHANGE_ME_superuser
LEAGUE_DB_PASSWORD=CHANGE_ME_league
TOUR_DB_PASSWORD=CHANGE_ME_tour
# Antelytics viewer shares this Postgres (its own role/db). Must equal the
# ANTELYTICS_DB_PASSWORD in /srv/antelytics/secrets.env.
ANTELYTICS_DB_PASSWORD=CHANGE_ME_antelytics

# ---- shared admin token (bot <-> web /api/admin, /api/bot) ------------------
LEAGUE_ADMIN_TOKEN=CHANGE_ME_admin_token
TOUR_ADMIN_TOKEN=CHANGE_ME_tour_admin_token

# ---- league Discord app + bot ----------------------------------------------
LEAGUE_DISCORD_TOKEN=
LEAGUE_DISCORD_CLIENT_ID=
LEAGUE_DISCORD_CLIENT_SECRET=
LEAGUE_DISCORD_GUILD_ID=
LEAGUE_OWNER_DISCORD_ID=
LEAGUE_ADMIN_ROLE_ID=
# openssl rand -base64 33
LEAGUE_AUTH_SECRET=
# optional league channels
RESULTS_CHANNEL_ID=
RESULTS_WEBHOOK_URL=
BOT_COMMANDS_CHANNEL_ID=
DEVOPS_CHANNEL_ID=
ANNOUNCEMENTS_CHANNEL_ID=

# ---- tour Discord app + bot (separate Discord application) ------------------
TOUR_DISCORD_TOKEN=
TOUR_DISCORD_CLIENT_ID=
TOUR_DISCORD_CLIENT_SECRET=
TOUR_GUILD_ID=
TOUR_OWNER_DISCORD_IDS=
# openssl rand -base64 33
TOUR_AUTH_SECRET=
